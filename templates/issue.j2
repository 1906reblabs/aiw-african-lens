</nav>

<div class="masthead">
  <div class="masthead-inner">
    <div class="mh-series">
      AIW Monthly Intelligence Review &nbsp;·&nbsp; {{ e.edition_id }}
    </div>
    <h1>{{ e.title }}{% if e.title_sub %}<br><em>{{ e.title_sub }}</em>{% endif %}</h1>
    {% if e.deck %}<p class="mh-deck">{{ e.deck }}</p>{% endif %}
    <div class="mh-meta-row">
      <span>{{ e.date }}</span>
      {% if e.window_start and e.window_end %}
      <span class="dot">·</span>
      <span>Window: {{ e.window_start }} → {{ e.window_end }}</span>
      {% endif %}
      <span class="dot">·</span>
      <span>Published 06:00 SAST, last Wednesday of the month</span>
    </div>
    {% if e.masthead_stats %}
    <div class="mh-signals">
      {% for stat in e.masthead_stats %}
      <div class="mh-sig"><div class="mh-sig-val">{{ stat.value }}</div><div class="mh-sig-lbl">{{ stat.label }}</div></div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>

<div class="toc-bar">
  <div class="toc-inner">
    <div class="toc-item"><a href="#thesis">§1 Thesis</a></div>
    <div class="toc-item"><a href="#brief">§2 Brief</a></div>
    <div class="toc-item"><a href="#signals">§3 Signals</a></div>
    <div class="toc-item"><a href="#essays">§4 Essays</a></div>
    <div class="toc-item"><a href="#engineering">§5 Engineering</a></div>
    <div class="toc-item"><a href="#commercial">§6 Commercial</a></div>
    <div class="toc-item"><a href="#policy">§7 Policy</a></div>
    <div class="toc-item"><a href="#builders">§8 Builders</a></div>
    <div class="toc-item"><a href="#research">§9 Research</a></div>
    <div class="toc-item"><a href="#scenarios">§10 Scenarios</a></div>
    <div class="toc-item"><a href="#reading">§11 Reading</a></div>
  </div>
</div>

<div class="main">

  <!-- §1 EDITOR'S THESIS -->
  <div class="sec" id="thesis">
    <span class="sec-num">§1</span><span class="sec-title">Editor's Thesis</span><div class="sec-line"></div>
  </div>
  <div class="opening-frame">
    {{ e.thesis.statement_html }}
  </div>
  <div class="thesis-support">
    {{ e.thesis.evidence_html }}
    {{ e.thesis.implications_html }}
  </div>
  {% if e.thesis.falsification %}
  <div class="thesis-falsify">
    <div class="tf-label">What Would Make This Wrong</div>
    <p>{{ e.thesis.falsification }}</p>
  </div>
  {% endif %}
  {% if e.thesis.last_month_verdict %}
  <div class="thesis-verdict {{ e.thesis.verdict_css }}">
    <span class="tv-badge">Last Month's Thesis — {{ e.thesis.last_month_verdict }}</span>
    <p>{{ e.thesis.last_month_verdict_text }}</p>
  </div>
  {% endif %}

  <!-- §2 EXECUTIVE BRIEF -->
  <div class="sec" id="brief">
    <span class="sec-num">§2</span><span class="sec-title">Executive Brief</span><div class="sec-line"></div>
  </div>
  {% for item in e.executive_brief.briefs %}
  <div class="brief-item">
    <div class="brief-num">{{ "%02d"|format(loop.index) }}</div>
    <div class="brief-body">
      <h4>{{ item.headline }}</h4>
      <div class="brief-row"><span class="br-label">What happened</span>{{ item.what_happened }}</div>
      <div class="brief-row"><span class="br-label">Why it matters</span>{{ item.why_it_matters }}</div>
      <div class="brief-row"><span class="br-label">Watch</span>{{ item.watch }}</div>
    </div>
  </div>
  {% endfor %}
  {% if e.executive_brief.number_of_month.value %}
  <div class="number-of-month">
    <div class="notm-label">The Number of the Month</div>
    <div class="notm-value">{{ e.executive_brief.number_of_month.value }}</div>
    {% if e.executive_brief.number_of_month.label %}<div class="notm-context">{{ e.executive_brief.number_of_month.label }} — {{ e.executive_brief.number_of_month.context }}</div>{% endif %}
  </div>
  {% endif %}

  <!-- §3 SIGNALS & METRICS -->
  <div class="sec" id="signals">
    <span class="sec-num">§3</span><span class="sec-title">Signals &amp; Metrics</span><div class="sec-line"></div>
  </div>
  {% if e.signals_metrics.kpis %}
  <table class="kpi-table">
    <thead><tr><th>Metric</th><th>This Month</th><th>Trend</th><th>Trailing 3-Mo Avg</th><th>Note</th></tr></thead>
    <tbody>
      {% for kpi in e.signals_metrics.kpis %}
      <tr>
        <td>{{ kpi.label }}</td>
        <td class="kpi-val">{{ kpi.value }}</td>
        <td class="{{ kpi.trend_css }}">{{ kpi.trend_symbol }}</td>
        <td>{{ kpi.trailing_3mo_avg }}</td>
        <td class="kpi-note">{{ kpi.note }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% for m in e.signals_metrics.metrics_of_month %}
  <div class="metric-card">
    <h4>Metric of the Month — {{ m.title }}</h4>
    <div class="mc-body">{{ m.body_html }}</div>
  </div>
  {% endfor %}
  {% if e.signals_metrics.coverage_note %}
  <p class="coverage-note">{{ e.signals_metrics.coverage_note }}</p>
  {% endif %}

  <!-- §4 DEEP RESEARCH ESSAYS -->
  <div class="sec" id="essays">
    <span class="sec-num">§4</span><span class="sec-title">Deep Research Essays</span><div class="sec-line"></div>
  </div>
  {% for essay in e.deep_research_essays %}
  <div class="essay-card">
    {% if essay.tags %}
    <div class="essay-tags">
      {% for tag in essay.tags %}<span class="sc-tag {{ tag.css|default('tag-research') }}">{{ tag.label|default(tag) }}</span>{% endfor %}
    </div>
    {% endif %}
    <h2 class="essay-title">{{ essay.title }}</h2>
    {% if essay.dek %}<p class="essay-dek">{{ essay.dek }}</p>{% endif %}
    <div class="essay-body">
      {{ essay.hook_html }}
      {{ essay.context_stakes_html }}
      {{ essay.core_argument_html }}
    </div>
    {% if essay.evidence_chain_html %}
    <div class="essay-evidence"><div class="ee-label">Evidence</div>{{ essay.evidence_chain_html }}</div>
    {% endif %}
    {% if essay.counterargument_html %}
    <div class="essay-counter"><div class="ec-label">The Strongest Counterargument</div>{{ essay.counterargument_html }}</div>
    {% endif %}
    {% if essay.strategic_implications_html %}
    <div class="essay-implications"><div class="ei-label">Strategic Implications</div>{{ essay.strategic_implications_html }}</div>
    {% endif %}
    {% if essay.falsification %}
    <div class="essay-falsify"><div class="ef-label">What Would Change This View</div><p>{{ essay.falsification }}</p></div>
    {% endif %}
    <div class="essay-meta">~{{ essay.word_count }} words</div>
  </div>
  {% endfor %}

  <!-- §5 ENGINEERING FRONTIER -->
  <div class="sec" id="engineering">
    <span class="sec-num">§5</span><span class="sec-title">Engineering Frontier</span><div class="sec-line"></div>
  </div>
  {% if e.engineering_frontier.opening_html %}<div class="thesis-support">{{ e.engineering_frontier.opening_html }}</div>{% endif %}
  <div class="layer-grid">
    <div class="layer-card"><h4>⚡ Power</h4><div class="lc-body">{{ e.engineering_frontier.power_html }}</div></div>
    <div class="layer-card"><h4>🧱 Compute</h4><div class="lc-body">{{ e.engineering_frontier.compute_html }}</div></div>
    <div class="layer-card"><h4>🌐 Connectivity</h4><div class="lc-body">{{ e.engineering_frontier.connectivity_html }}</div></div>
  </div>
  {% if e.engineering_frontier.dependency_watch %}
  <div class="dependency-watch"><div class="dw-label">Dependency Watch — for Scenarios &amp; Forecasts</div>{{ e.engineering_frontier.dependency_watch }}</div>
  {% endif %}

  <!-- §6 COMMERCIAL STRATEGY -->
  <div class="sec" id="commercial">
    <span class="sec-num">§6</span><span class="sec-title">Commercial Strategy</span><div class="sec-line"></div>
  </div>
  <div class="policy-block">
    <div class="pb-body">{{ e.commercial_strategy.lead_html }}</div>
  </div>
  <div class="policy-block">
    <div class="pb-head">Capital Flow Read</div>
    <div class="pb-body">{{ e.commercial_strategy.capital_flow_read_html }}</div>
  </div>
  <div class="policy-block">
    <div class="pb-head">Competitive Structure</div>
    <div class="pb-body">{{ e.commercial_strategy.competitive_structure_html }}</div>
  </div>
  <div class="policy-block">
    <div class="pb-head">For the Operator — Build / Buy / Partner</div>
    <div class="pb-body">{{ e.commercial_strategy.for_operator_html }}</div>
  </div>

  <!-- §7 POLICY & GEOPOLITICS -->
  <div class="sec" id="policy">
    <span class="sec-num">§7</span><span class="sec-title">Policy &amp; Geopolitics</span><div class="sec-line"></div>
  </div>
  <div class="policy-block">
    <div class="pb-body">{{ e.policy_geopolitics.lead_html }}</div>
  </div>
  {% if e.policy_geopolitics.actor_map %}
  <div class="actor-grid">
    {% for a in e.policy_geopolitics.actor_map %}
    <div class="actor-card">
      <div class="actor-name">{{ a.actor }}</div>
      <div class="actor-row"><span class="ar-label">Instrument</span>{{ a.instrument }}</div>
      <div class="actor-row"><span class="ar-label">African Counterpart Leverage</span>{{ a.leverage }}</div>
      <div class="actor-row"><span class="ar-label">Degrees of Freedom</span>{{ a.degrees_of_freedom }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% if e.policy_geopolitics.convergence_rows %}
  <table class="convergence-table">
    <thead><tr><th>Country</th><th>Policy Status</th><th>Key Development</th><th>Convergence Signal</th></tr></thead>
    <tbody>
      {% for row in e.policy_geopolitics.convergence_rows %}
      <tr>
        <td><strong>{{ row.country }}</strong></td>
        <td>{{ row.status }}</td>
        <td>{{ row.development }}</td>
        <td>{{ row.convergence }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if e.policy_geopolitics.branch_points %}
  <ul class="branch-points">
    {% for bp in e.policy_geopolitics.branch_points %}
    <li>{{ bp }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  <!-- §8 AFRICAN BUILDERS -->
  <div class="sec" id="builders">
    <span class="sec-num">§8</span><span class="sec-title">African Builders</span><div class="sec-line"></div>
  </div>
  {% for b in e.african_builders %}
  <div class="builder-card">
    <div class="builder-bar" style="{{ b.flag_style }}"></div>
    <div class="builder-header">
      <div>
        <div class="builder-name">{{ b.name }}</div>
        <div class="builder-meta">{{ b.role }}{% if b.country %} · {{ b.country }}{% endif %}{% if b.layer %} · {{ b.layer }}{% endif %}</div>
        {% if b.badges %}
        <div class="builder-badges">{% for badge in b.badges %}<span class="b-badge">{{ badge }}</span>{% endfor %}</div>
        {% endif %}
      </div>
    </div>
    <div class="builder-body">
      <div class="builder-sub">Who{% if b.sourcing %}<span class="sourcing-tag">Sourcing: {{ b.sourcing }}</span>{% endif %}</div>
      {{ b.who_html }}
      <div class="builder-sub">Why It Matters Beyond Them</div>
      {{ b.why_it_matters_html }}
      <div class="builder-sub">The Bet</div>
      {{ b.the_bet_html }}
    </div>
  </div>
  {% endfor %}

  <!-- §9 MODELS, PAPERS & REPOSITORIES -->
  <div class="sec" id="research">
    <span class="sec-num">§9</span><span class="sec-title">Models, Papers &amp; Repositories</span><div class="sec-line"></div>
  </div>
  <div class="thesis-support">{{ e.models_papers_repos.lead_html }}</div>
  {% if e.models_papers_repos.benchmark_board.rows %}
  <table class="benchmark-table">
    <thead>
      <tr>
        <th>Language</th>
        {% for col in e.models_papers_repos.benchmark_board.columns %}<th>{{ col }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in e.models_papers_repos.benchmark_board.rows %}
      <tr class="{% if row.changed %}changed{% endif %}">
        <td>{{ row.language }}</td>
        {% for val in row.cells %}<td>{{ val }}</td>{% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if e.models_papers_repos.benchmark_note_html %}<div class="thesis-support">{{ e.models_papers_repos.benchmark_note_html }}</div>{% endif %}
  {% for r in e.models_papers_repos.repository_health %}
  <div class="repo-card">
    <h4>Repository Health — {{ r.name }}</h4>
    {{ r.body_html }}
  </div>
  {% endfor %}
  {% if e.models_papers_repos.dark_zones %}
  <p class="dark-zones">Dark zones: {{ e.models_papers_repos.dark_zones }}</p>
  {% endif %}

  <!-- §10 SCENARIOS & FORECASTS -->
  <div class="sec" id="scenarios">
    <span class="sec-num">§10</span><span class="sec-title">Scenarios &amp; Forecasts</span><div class="sec-line"></div>
  </div>
  {% for s in e.scenarios_forecasts.scenarios %}
  <div class="scenario-card {{ s.type_css }}">
    <div class="scenario-header">
      <span class="scenario-name">{{ s.name }}</span>
      <div class="scenario-badges">
        <span class="sb-badge">{{ s.type }}</span>
        <span class="sb-badge {{ s.prob_css }}">{{ s.probability_band }}</span>
        <span class="sb-badge">{{ s.time_horizon }}</span>
      </div>
    </div>
    <div class="scenario-body">
      <div class="sc-row"><div class="sc-label">Trigger Conditions</div>{{ s.trigger_conditions_html }}</div>
      <div class="sc-row"><div class="sc-label">Stack-Wide Cascade</div>{{ s.stack_cascade_html }}</div>
      <div class="sc-label">Response Options</div>
      <div class="response-grid">
        <div class="response-col"><div class="rc-label">Investor</div>{{ s.response_options.investor_html }}</div>
        <div class="response-col"><div class="rc-label">Policymaker</div>{{ s.response_options.policymaker_html }}</div>
        <div class="response-col"><div class="rc-label">Builder</div>{{ s.response_options.builder_html }}</div>
      </div>
      <div class="sc-indicators"><div class="sc-label">Early Indicators — Confirm or Deny</div>{{ s.early_indicators_html }}</div>
    </div>
  </div>
  {% endfor %}
  {% if e.scenarios_forecasts.watchlist_update %}
  <div class="scenario-followup">
    <div class="sf-label">Watchlist Update — Carried Forward</div>
    <ul>{% for w in e.scenarios_forecasts.watchlist_update %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
  {% if e.scenarios_forecasts.resolved_this_month %}
  <div class="scenario-followup">
    <div class="sf-label">Resolved This Month</div>
    <ul>{% for r in e.scenarios_forecasts.resolved_this_month %}<li>{{ r }}</li>{% endfor %}</ul>
  </div>
  {% endif %}

  <!-- §11 READING LIST -->
  <div class="sec" id="reading">
    <span class="sec-num">§11</span><span class="sec-title">Reading List</span><div class="sec-line"></div>
  </div>
  <ol class="reading-list">
    {% for item in e.reading_list %}
    <li>
      <a href="{{ item.url }}" target="_blank">{{ item.title }}</a>
      <span class="rl-meta">— {{ item.source }}{% if item.date %}, {{ item.date }}{% endif %}</span>
      <div class="rl-annotation">{{ item.annotation_html }}</div>
    </li>
    {% endfor %}
  </ol>

  {% if e.editorial_note_html %}
  <div class="editorial-note">
    <div class="en-label">Editorial Note — {{ e.edition_id }}</div>
    {{ e.editorial_note_html }}
  </div>
  {% endif %}

</div><!-- /main -->

<footer>
  <p><strong>AIW African Lens Monthly Intelligence Review — {{ e.edition_id }}</strong></p>
  <p style="margin-top:6px;">{{ e.date }}{% if e.window_start and e.window_end %} · Window: {{ e.window_start }} → {{ e.window_end }}{% endif %} · Published 06:00 SAST</p>
  <div class="footer-links">
    <a href="index.html">All Monthly Editions</a>
    <a href="../weekly/index.html">Weekly Archive (Vol. I)</a>
    <a href="../index.html">Full Archive</a>
    {% if e.prev_edition %}<a href="{{ e.prev_edition }}">← {{ e.prev_edition_id }}</a>{% endif %}
    {% if e.next_edition %}<a href="{{ e.next_edition }}">Next Edition →</a>{% endif %}
    <a href="https://simphiwemlotshwa.substack.com/" target="_blank">Subscribe on Substack</a>
  </div>
  <p style="margin-top:16px;">AIW African Lens · AI · Machine Learning · Data Science · Across 54 Nations</p>
  <p style="margin-top:6px;">© {{ e.date.split(' ')[-1] if e.date else '2026' }} AIW African Lens · Archive hosted on GitHub Pages</p>
</footer>

</body>
</html>
