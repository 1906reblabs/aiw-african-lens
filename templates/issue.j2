<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ e.edition_id }} — {{ e.title }}{% if e.title_sub %}: {{ e.title_sub }}{% endif %} · AIW African Lens Monthly Intelligence Review</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0e0e0e;
    --cream: #faf7f2;
    --gold: #c8922a;
    --gold-light: #f0d898;
    --rust: #b84c2a;
    --teal: #1a6b5e;
    --teal-light: #e3f2ee;
    --border: #d8d0c4;
    --mid-grey: #7a7570;
    --light-grey: #ede9e3;
    --deep-blue: #0a1628;
    --deep-blue-mid: #0f2040;
    --hybrid: #5e35b1;
    --hybrid-light: #ede7f6;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--cream); color: var(--ink); font-family: 'DM Sans', sans-serif; line-height: 1.7; }
  a { color: var(--teal); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── NAV ── */
  nav {
    background: var(--deep-blue); padding: 14px 32px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid rgba(200,146,42,0.2);
  }
  .nav-brand { font-family: 'Playfair Display', serif; font-weight: 900; font-size: 18px; color: #fff; }
  .nav-brand span { color: var(--gold); }
  .nav-links { display: flex; gap: 24px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; }
  .nav-links a { color: #8a99b8; }
  .nav-links a:hover { color: var(--gold); text-decoration: none; }

  /* ── MASTHEAD ── */
  .masthead { background: var(--deep-blue); padding: 64px 32px 52px; position: relative; overflow: hidden; }
  .masthead::before { content: ''; position: absolute; top: -60px; right: -60px; width: 320px; height: 320px; border: 1px solid rgba(200,146,42,0.12); border-radius: 50%; }
  .masthead::after { content: ''; position: absolute; top: -20px; right: -20px; width: 180px; height: 180px; border: 1px solid rgba(200,146,42,0.08); border-radius: 50%; }
  .masthead-inner { max-width: 860px; margin: 0 auto; position: relative; z-index: 1; }
  .mh-series { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 18px; display: flex; align-items: center; gap: 16px; }
  .mh-series::after { content: ''; flex: 1; height: 1px; background: rgba(200,146,42,0.3); max-width: 120px; }
  .masthead h1 { font-family: 'Playfair Display', serif; font-size: clamp(30px,5vw,52px); font-weight: 900; color: #fff; line-height: 1.08; letter-spacing: -0.02em; margin-bottom: 20px; max-width: 720px; }
  .masthead h1 em { font-style: italic; color: var(--gold); }
  .mh-deck { font-size: 15px; color: #8a99b8; line-height: 1.65; max-width: 640px; margin-bottom: 28px; }
  .mh-meta-row { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.08em; color: #4a5a78; }
  .mh-meta-row .dot { color: rgba(200,146,42,0.4); }
  .mh-signals { display: flex; gap: 20px; margin-top: 32px; padding-top: 28px; border-top: 1px solid rgba(255,255,255,0.06); flex-wrap: wrap; }
  .mh-sig { display: flex; flex-direction: column; gap: 3px; }
  .mh-sig-val { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: var(--gold); line-height: 1; }
  .mh-sig-lbl { font-family: 'DM Mono', monospace; font-size: 8.5px; letter-spacing: 0.16em; text-transform: uppercase; color: #4a5a78; }

  /* ── TOC ── */
  .toc-bar { background: var(--deep-blue-mid); border-bottom: 1px solid rgba(200,146,42,0.15); }
  .toc-inner { max-width: 860px; margin: 0 auto; padding: 0 32px; display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .toc-inner::-webkit-scrollbar { display: none; }
  .toc-item { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: #5a6a88; padding: 12px 14px; white-space: nowrap; border-right: 1px solid rgba(255,255,255,0.04); }
  .toc-item:first-child { padding-left: 0; }
  .toc-item a { color: inherit; }
  .toc-item:hover a { color: var(--gold); }

  /* ── MAIN / SECTION LABELS ── */
  .main { max-width: 860px; margin: 0 auto; padding: 0 24px 80px; }
  .sec { display: flex; align-items: center; gap: 12px; margin: 56px 0 28px; }
  .sec-num { font-family: 'Playfair Display', serif; font-size: 11px; font-weight: 700; color: var(--gold); min-width: 24px; }
  .sec-title { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--mid-grey); }
  .sec-line { flex: 1; height: 1px; background: var(--border); }
  .sec::after { content: ''; height: 2px; width: 40px; background: var(--ink); display: block; }
  .sec-model { font-family: 'DM Mono', monospace; font-size: 8.5px; letter-spacing: 0.08em; color: var(--border); text-transform: uppercase; }

  /* ── §1 OPENING FRAME / THESIS ── */
  .opening-frame { background: var(--ink); padding: 32px 36px; position: relative; overflow: hidden; margin-bottom: 14px; }
  .opening-frame::before { content: '"'; font-family: 'Playfair Display', serif; font-size: 200px; color: rgba(200,146,42,0.06); position: absolute; top: -40px; left: 20px; line-height: 1; font-weight: 900; }
  .opening-frame p { font-family: 'DM Sans', sans-serif; font-size: 16px; line-height: 1.75; color: #c8d4e8; position: relative; z-index: 1; max-width: 720px; }
  .thesis-support { font-size: 14.5px; line-height: 1.75; color: #2a2520; margin-bottom: 14px; }
  .thesis-support p { margin-bottom: 12px; }
  .thesis-falsify { background: var(--light-grey); border-left: 2px solid var(--border); padding: 14px 18px; margin-bottom: 12px; }
  .tf-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 5px; }
  .thesis-falsify p { font-size: 13px; color: #2a2520; }
  .thesis-verdict { border: 1px solid var(--border); padding: 14px 18px; }
  .thesis-verdict p { font-size: 13px; color: #2a2520; margin-top: 6px; }
  .tv-badge { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 10px; }
  .verdict-confirmed .tv-badge { background: var(--teal-light); color: var(--teal); }
  .verdict-revised .tv-badge { background: #fef3e2; color: #9a6210; }
  .verdict-abandoned .tv-badge { background: #fbe9e6; color: var(--rust); }
  .verdict-na .tv-badge { background: var(--light-grey); color: var(--mid-grey); }

  /* ── §2 EXECUTIVE BRIEF ── */
  .brief-item { background: #fff; border: 1px solid var(--border); padding: 16px 20px; margin-bottom: 8px; display: flex; gap: 14px; }
  .brief-num { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 900; color: var(--light-grey); min-width: 30px; }
  .brief-body h4 { font-size: 14.5px; font-weight: 600; color: var(--ink); margin-bottom: 8px; }
  .brief-row { font-size: 13px; line-height: 1.6; margin-bottom: 4px; }
  .brief-row .br-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); margin-right: 6px; }
  .number-of-month { background: var(--deep-blue); padding: 18px 22px; margin-top: 6px; }
  .notm-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .notm-value { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: #fff; }
  .notm-context { font-size: 12.5px; color: #8a99b8; margin-top: 6px; }

  /* ── §3 SIGNALS & METRICS ── */
  .kpi-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
  .kpi-table th { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid-grey); background: var(--light-grey); padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
  .kpi-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); font-size: 13px; vertical-align: top; }
  .kpi-table tr:last-child td { border-bottom: none; }
  .kpi-val { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 15px; }
  .trend-up { color: var(--teal); } .trend-down { color: var(--rust); } .trend-flat { color: var(--mid-grey); }
  .kpi-note { font-size: 11.5px; color: var(--mid-grey); }
  .metric-card { background: #fff; border: 1px solid var(--border); border-top: 3px solid var(--gold); padding: 16px 20px; margin-bottom: 8px; }
  .metric-card h4 { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
  .metric-card .mc-body { font-size: 13.5px; line-height: 1.7; color: #2a2520; }
  .coverage-note { font-size: 12px; color: var(--mid-grey); font-style: italic; border-left: 2px solid var(--border); padding-left: 12px; }

  /* ── §4 DEEP RESEARCH ESSAYS ── */
  .essay-card { background: #fff; border: 1px solid var(--border); padding: 32px 32px 28px; margin-bottom: 24px; }
  .essay-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .sc-tag { font-family: 'DM Mono', monospace; font-size: 8.5px; letter-spacing: 0.1em; text-transform: uppercase; padding: 2px 8px; border-radius: 2px; }
  .tag-policy { background: var(--teal-light); color: var(--teal); }
  .tag-infra { background: #f3e5f5; color: #6a1b9a; }
  .tag-geo { background: #e3f2fd; color: #1565c0; }
  .tag-tech { background: #fef3e2; color: #9a6210; }
  .tag-security { background: #fbe9e6; color: var(--rust); }
  .tag-ecosystem { background: #e8f5e9; color: #2e7d32; }
  .tag-research { background: var(--hybrid-light); color: var(--hybrid); }
  .tag-capital { background: #e0f7fa; color: #00695c; }
  .essay-title { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 900; line-height: 1.25; margin-bottom: 10px; }
  .essay-dek { font-size: 15px; color: var(--mid-grey); line-height: 1.6; margin-bottom: 20px; }
  .essay-body { font-size: 15px; line-height: 1.8; color: #2a2520; }
  .essay-body p { margin-bottom: 14px; }
  .essay-evidence, .essay-counter, .essay-implications { margin-top: 18px; padding: 16px 20px; background: var(--light-grey); border-left: 2px solid var(--border); font-size: 13.5px; line-height: 1.7; color: #2a2520; }
  .ee-label, .ec-label, .ei-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 8px; }
  .essay-falsify { margin-top: 18px; padding: 14px 18px; background: #fff; border: 1px solid var(--border); }
  .ef-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rust); margin-bottom: 5px; }
  .essay-falsify p { font-size: 13px; }
  .essay-meta { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--mid-grey); margin-top: 14px; text-align: right; }

  /* ── §5 ENGINEERING FRONTIER / §6 COMMERCIAL STRATEGY (shared layer-grid / policy-block) ── */
  .layer-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .layer-card { background: #fff; border: 1px solid var(--border); padding: 18px 20px; }
  .layer-card h4 { font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .layer-card .lc-body { font-size: 13.5px; line-height: 1.7; color: #2a2520; }
  .dependency-watch { background: var(--ink); color: var(--cream); padding: 14px 18px; font-size: 12.5px; line-height: 1.6; }
  .dw-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 5px; }

  .policy-block { background: #fff; border: 1px solid var(--border); border-top: 3px solid var(--teal); padding: 22px 24px; margin-bottom: 10px; }
  .pb-head { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--teal); margin-bottom: 12px; }
  .pb-body { font-size: 14px; line-height: 1.75; color: #2a2520; }
  .pb-body p { margin-bottom: 12px; }
  .pb-body p:last-child { margin-bottom: 0; }

  /* ── §7 POLICY & GEOPOLITICS ── */
  .actor-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 14px 0; }
  .actor-card { background: #fff; border: 1px solid var(--border); padding: 14px 18px; }
  .actor-name { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 14px; margin-bottom: 8px; }
  .actor-row { font-size: 12.5px; margin-bottom: 5px; line-height: 1.55; }
  .actor-row .ar-label { font-family: 'DM Mono', monospace; font-size: 8.5px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--mid-grey); display: block; }
  .convergence-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 12.5px; }
  .convergence-table th { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mid-grey); background: var(--light-grey); padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border); }
  .convergence-table td { padding: 9px 12px; border-bottom: 1px solid var(--border); vertical-align: top; line-height: 1.55; }
  .convergence-table tr:last-child td { border-bottom: none; }
  .branch-points { list-style: none; }
  .branch-points li { background: var(--light-grey); border-left: 2px solid var(--gold); padding: 10px 14px; margin-bottom: 6px; font-size: 13px; }

  /* ── §8 AFRICAN BUILDERS ── */
  .builder-card { background: #fff; border: 1px solid var(--border); margin-bottom: 10px; overflow: hidden; }
  .builder-bar { height: 4px; }
  .builder-header { padding: 16px 22px 12px; display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; flex-wrap: wrap; border-bottom: 1px solid var(--border); }
  .builder-name { font-family: 'Playfair Display', serif; font-size: 19px; font-weight: 900; }
  .builder-meta { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--mid-grey); margin-top: 3px; }
  .builder-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
  .b-badge { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.06em; padding: 2px 8px; background: var(--light-grey); color: var(--mid-grey); }
  .builder-body { padding: 16px 22px 20px; }
  .builder-sub { font-family: 'DM Mono', monospace; font-size: 9.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid-grey); margin: 12px 0 6px; }
  .builder-sub:first-child { margin-top: 0; }
  .builder-body p { font-size: 13.5px; line-height: 1.7; color: #2a2520; }
  .sourcing-tag { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--mid-grey); float: right; }

  /* ── §9 MODELS, PAPERS & REPOSITORIES ── */
  .benchmark-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 12.5px; }
  .benchmark-table th { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--mid-grey); background: var(--light-grey); padding: 8px 10px; text-align: left; border-bottom: 1px solid var(--border); }
  .benchmark-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); }
  .benchmark-table tr.changed td { background: #fffbf0; }
  .benchmark-table tr.changed td:first-child { border-left: 2px solid var(--gold); }
  .repo-card { background: #fff; border: 1px solid var(--border); border-top: 3px solid var(--hybrid); padding: 14px 18px; margin-bottom: 8px; }
  .repo-card h4 { font-size: 13.5px; font-weight: 600; margin-bottom: 6px; }
  .repo-card p { font-size: 13px; line-height: 1.65; color: #2a2520; }
  .dark-zones { font-size: 12px; color: var(--mid-grey); font-style: italic; margin-top: 10px; }

  /* ── §10 SCENARIOS & FORECASTS ── */
  .scenario-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--ink); margin-bottom: 12px; }
  .scenario-fragility { border-left-color: var(--rust); }
  .scenario-contrarian { border-left-color: var(--gold); }
  .scenario-hybrid { border-left-color: var(--hybrid); }
  .scenario-header { padding: 14px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; }
  .scenario-name { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; }
  .scenario-badges { display: flex; gap: 6px; flex-wrap: wrap; }
  .sb-badge { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; padding: 2px 8px; background: var(--light-grey); color: var(--mid-grey); }
  .sb-badge.prob-low { background: var(--teal-light); color: var(--teal); }
  .sb-badge.prob-medium { background: #fef3e2; color: #9a6210; }
  .sb-badge.prob-high { background: #fbe9e6; color: var(--rust); }
  .scenario-body { padding: 18px 20px; }
  .sc-row { margin-bottom: 14px; }
  .sc-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 6px; }
  .sc-row p, .sc-indicators p { font-size: 13.5px; line-height: 1.7; color: #2a2520; }
  .response-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .response-col { background: var(--light-grey); padding: 12px 14px; }
  .rc-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal); margin-bottom: 6px; }
  .response-col p { font-size: 12.5px; line-height: 1.6; color: #2a2520; }
  .sc-indicators { background: #fffbf0; border: 1px solid var(--border); padding: 12px 16px; }
  .scenario-followup { background: #fff; border: 1px solid var(--border); padding: 16px 20px; margin-bottom: 8px; }
  .sf-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 10px; }
  .scenario-followup ul { list-style: none; }
  .scenario-followup li { font-size: 13px; line-height: 1.65; padding: 6px 0; border-bottom: 1px solid var(--light-grey); }
  .scenario-followup li:last-child { border-bottom: none; }

  /* ── §11 READING LIST ── */
  .reading-list { list-style: none; counter-reset: rl; }
  .reading-list li { counter-increment: rl; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .reading-list li:last-child { border-bottom: none; }
  .reading-list li::before { content: counter(rl) '.'; font-family: 'DM Mono', monospace; color: var(--gold); margin-right: 8px; }
  .reading-list a { font-weight: 600; color: var(--ink); }
  .rl-meta { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--mid-grey); }
  .rl-annotation { font-size: 13px; color: #2a2520; margin-top: 4px; margin-left: 18px; line-height: 1.6; }

  /* ── EDITORIAL NOTE / FOOTER ── */
  .editorial-note { background: var(--light-grey); border: 1px solid var(--border); padding: 18px 22px; margin-top: 48px; font-size: 12px; color: var(--mid-grey); line-height: 1.65; }
  .en-label { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mid-grey); margin-bottom: 8px; }
  footer { background: var(--ink); color: #7a8294; text-align: center; padding: 36px 24px; font-family: 'DM Mono', monospace; font-size: 10px; letter-spacing: 0.06em; }
  footer strong { color: #c8d4e8; }
  footer a { color: #7a8294; }
  footer a:hover { color: var(--gold); }
  .footer-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 20px; margin-top: 12px; }

  @media (max-width: 780px) {
    .layer-grid { grid-template-columns: 1fr; }
    .actor-grid { grid-template-columns: 1fr; }
    .response-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 680px) {
    .masthead { padding: 40px 20px 36px; }
    .main { padding: 0 16px 60px; }
    nav { padding: 12px 18px; }
    .opening-frame { padding: 24px 22px; }
    .essay-card { padding: 22px 20px; }
  }
</style>
</head>
